# Copy this file to .env and fill in real values. Never commit .env to git.

# --- Exchange / broker API keys (use sandbox/paper-trading keys until Stage 3 incubation) ---
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_WALLET_PRIVATE_KEY=

# --- Data provider keys, if any ---
DATA_PROVIDER_API_KEY=

# --- Per-bot sub-account isolation (add one pair per bot once you have more than one live) ---
BOT1_ACCOUNT_PRIVATE_KEY=
BOT2_ACCOUNT_PRIVATE_KEY=

# --- Notifications (optional: wire a bot to alert you on errors/fills) ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
